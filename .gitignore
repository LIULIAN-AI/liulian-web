# ─── Production secrets (NEVER commit these) ───────────────────────────────
.env.local
.env.production
.env*.local

# ─── Next.js build ─────────────────────────────────────────────────────────
.next/
out/

# ─── Node ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── TypeScript ────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Contentlayer ──────────────────────────────────────────────────────────
.contentlayer/

# ─── IDE ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp

# ─── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Tests ──────────────────────────────────────────────────────────────────
# Committed: infrastructure (setup/utils), component/unit tests, regression.
# Only scratch/exploratory tests should be kept local (add them as
# __tests__/scratch-* or similar and they'll be caught by default gitignore).

# ─── Playwright ───────────────────────────────────────────────────────────
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# ─── Storybook build output ────────────────────────────────────────────────
storybook-static/

# ─── @liulian/ui-react ─────────────────────────────────────────────────────
packages/*/node_modules/
packages/*/dist/
