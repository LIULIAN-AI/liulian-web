{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$comment": "LIULIAN canonical design tokens. Source: feat/gui-demo iteration 2 (styles/main.css). Edit here; build script generates per-platform exports.",

  "color": {
    "canvas": {
      "warm":     { "value": "#FBFBFA", "$type": "color", "$description": "Warm paper, primary background. Never use #fff." },
      "soft":     { "value": "#F7F6F3", "$type": "color" },
      "warmer":   { "value": "#F2F0EA", "$type": "color" }
    },
    "surface": {
      "pure":     { "value": "#FFFFFF", "$type": "color", "$description": "Card surface; functional only." },
      "shade":    { "value": "#FAFAF9", "$type": "color" }
    },
    "ink": {
      "charcoal": { "value": "#131313", "$type": "color", "$description": "Body text. Never use #000." },
      "strong":   { "value": "#1F1F1F", "$type": "color" },
      "soft":     { "value": "#34373B", "$type": "color" },
      "muted":    { "value": "#666A70", "$type": "color" },
      "faint":    { "value": "#94989D", "$type": "color" },
      "quiet":    { "value": "#C0C2C5", "$type": "color" }
    },
    "unibe-red": {
      "DEFAULT":  { "value": "#E20613", "$type": "color", "$description": "Brand anchor. Spot color only. Max 2 visible per viewport on most pages." },
      "deep":     { "value": "#B00010", "$type": "color", "$description": "Hover/focus/destructive-confirm." },
      "tint":     { "value": "#FDEBEC", "$type": "color", "$description": "Pill backgrounds, CI band fills." },
      "tint-2":   { "value": "#FAD9DC", "$type": "color" },
      "text":     { "value": "#9F2F2D", "$type": "color" }
    },
    "status": {
      "green":      { "value": "#2E7D43", "$type": "color" },
      "green-pale": { "value": "#E5F0E7", "$type": "color" },
      "blue":       { "value": "#1F6C9F", "$type": "color" },
      "blue-pale":  { "value": "#E1F1FB", "$type": "color" },
      "amber":      { "value": "#946400", "$type": "color" },
      "amber-pale": { "value": "#FBF1D9", "$type": "color" }
    },
    "hairline": {
      "DEFAULT":  { "value": "#E8E7E2", "$type": "color" },
      "strong":   { "value": "#DEDCD4", "$type": "color" },
      "stronger": { "value": "#C9C7BF", "$type": "color" }
    },
    "unibe-secondary": {
      "$comment": "UniBe corporate secondary (from unibeCols R package). CHART SERIES ONLY — never UI fill.",
      "ocean":   { "value": "#0066B3", "$type": "color" },
      "green":   { "value": "#509A39", "$type": "color" },
      "apricot": { "value": "#E6863A", "$type": "color" }
    }
  },

  "font": {
    "display": { "value": ["Fraunces", "Instrument Serif", "Times New Roman", "serif"], "$type": "fontFamily" },
    "body":    { "value": ["Switzer", "SF Pro Text", "Helvetica Neue", "sans-serif"], "$type": "fontFamily" },
    "mono":    { "value": ["JetBrains Mono", "SF Mono", "ui-monospace", "monospace"], "$type": "fontFamily" }
  },

  "fontSize": {
    "xs":   { "value": "10.5px" },
    "sm":   { "value": "12px" },
    "md":   { "value": "13.5px" },
    "lg":   { "value": "15px" },
    "xl":   { "value": "18px" },
    "2xl":  { "value": "22px" },
    "3xl":  { "value": "28px" },
    "4xl":  { "value": "38px" },
    "5xl":  { "value": "56px" },
    "6xl":  { "value": "96px" },
    "display": { "value": "144px" }
  },

  "spacing": {
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "7":  { "value": "32px" },
    "8":  { "value": "48px" },
    "9":  { "value": "64px" },
    "10": { "value": "96px" },
    "11": { "value": "128px" }
  },

  "radius": {
    "sm":   { "value": "4px" },
    "md":   { "value": "10px", "$description": "Card default" },
    "lg":   { "value": "14px" },
    "xl":   { "value": "20px" },
    "pill": { "value": "9999px" }
  },

  "border": {
    "hairline": { "value": "1px solid #E8E7E2" }
  },

  "motion": {
    "ease-out":     { "value": "cubic-bezier(0.22, 1, 0.36, 1)" },
    "ease-out-quart": { "value": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "ease-in-out":  { "value": "cubic-bezier(0.65, 0, 0.35, 1)" },
    "duration-fast":   { "value": "200ms" },
    "duration-medium": { "value": "300ms" },
    "duration-slow":   { "value": "600ms" }
  }
}
